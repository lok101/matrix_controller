# Google Sheets — матрицы и товары
# ID таблицы (из URL: https://docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_MATRIX_TABLE_ID=

# Рекомендуется указать явно; иначе gspread ищет service_account.json в CWD
GOOGLE_APPLICATION_CREDENTIALS=

# Kit Vending API (обязательные)
KIT_API_COMPANY_ID=
KIT_API_LOGIN=
KIT_API_PASSWORD=

# Kit Vending API — rate limiter (опционально)
KIT_API_REQUEST_PER_WINDOW=5
KIT_API_WINDOW_SECONDS=1
KIT_API_BACKOFF_SECONDS=1.0

# Валидация матриц перед загрузкой (true/false)
VALIDATE_MATRICES=true

# Таймауты deploy матриц (секунды)
MATRIX_LOAD_TIMEOUT=300
MATRIX_APPLY_TIMEOUT=300

# Интервал batch-опроса GetVMStates (секунды)
MATRIX_STATUS_POLL_INTERVAL=15

# Пауза между send_command (секунды)
MATRIX_COMMAND_SEND_DELAY=7

# Макс. попыток GetVMStates подряд при ошибке API на одном poll-цикле
MATRIX_POLL_API_MAX_RETRIES=10

# Пауза между retry send_command при rate limit / network (секунды)
MATRIX_RETRY_SEND_COMMAND_DELAY=10

# Scheduled mode: "*" — все матрицы, или список через запятую: matrix_a,matrix_b
SCHEDULED_MATRIX_NAMES=*

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
